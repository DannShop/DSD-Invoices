# ─────────────────────────────────────────────────────────────
# DSD-Invoices — Environment Variables
# Rename file ini jadi ".env" dan isi dengan nilai yang benar
# ─────────────────────────────────────────────────────────────

# Supabase — Cloud Sync (Phase 3)
# Dapatkan dari: supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxx

# Resend — Kirim Email Invoice Otomatis
# 1. Daftar gratis di resend.com (100 email/hari gratis)
# 2. Buat API key di: resend.com/api-keys
# 3. Paste di sini:
VITE_RESEND_API_KEY=re_xxxxxxxxxxxx

# Email pengirim (opsional)
# Kalau belum punya domain, pakai default: onboarding@resend.dev
# Kalau sudah punya domain, daftarkan dulu di resend.com/domains
VITE_EMAIL_FROM=invoice@domainlo.com

# Catatan:
# - Prefix VITE_ wajib agar Vite expose ke client-side
# - JANGAN commit file .env ke Git! Sudah ada di .gitignore
